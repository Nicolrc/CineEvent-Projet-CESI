{% extends"base.html.twig" %}

{% block title %} ADMIN - {{ parent() }} > Liste des événements {% endblock %}

{% block css %}
    <link rel="stylesheet" href="/assets/css/style_event_list.css">
{% endblock %}

{% block body %}
<div class="container-principal container-fluid px-5">
    <h1>Liste des événements</h1>
    <div class="event-card-container">
        {% for event in events %}
            <div class="event-card">
                {% if isAdmin  %}
                <a href="/AdminEvent/delete/{{ event.id }}?token={{ session.token }}"
                   class="btn-suppr"
                   onclick="return confirm('Supprimer cet événement ?')"
                   aria-label="Supprimer l'événement {{ event.nom }}">
                    <i class="bi bi-trash"></i>
                </a>
                {% endif %}

                {% if event.imageFileName %}
                    <img src="/uploads/images/{{ event.imageRepository }}/{{ event.imageFileName }}" class="event-image" alt="Image de l'événement : {{ event.nom }}">
                {% else %}
                    <div class="event-img d-flex align-items-center justify-content-center bg-dark text-muted">
                        <i class="bi bi-camera-video fs-1"></i>
                    </div>
                {% endif %}
                <div class="event-body">
                    <h5 class="card-title">{{ event.nom }}</h5>
                    <div class="price-date-container d-flex justify-content-between">
                        <span class="price-badge">{{ event.prix }}€</span>
                        <p class="card-text"><i class="bi bi-calendar"></i> {{ event.dateEvenement|date('d/m/Y') }}</p>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <a href="/event/showEvent/{{ event.id }}" class="btn btn-voir-event">Voir lévénement</a>
                        {% if isAdmin  %}
                        <a href="/AdminEvent/editEvent/{{ event.id }}?token={{ token }}" class="btn btn-modifier-event">Modifier</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
        <a href="/AdminEvent/add" class="text-decoration-none text-muted">
            <div class="card add-card">
                <div class="text-center">
                    <i class="bi bi-plus-circle fs-1"></i>
                    <p>Ajouter</p>
                </div>
            </div>
        </a>
    </div>
</div>
{% endblock %}