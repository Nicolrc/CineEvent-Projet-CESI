{% extends "base.html.twig" %}
{% block title %}ADMIN - {{ parent() }} - Ajout d'un événement ciném {% endblock %}

{% block css %}
    <link rel="stylesheet" href="/assets/css/style_event_add.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
{% endblock %}

{% block body %}
    <div class="card-container">
        <div class="card">
            <h1>Ajout d'un événement cinéma</h1>

            <form method="post" enctype="multipart/form-data" action="/AdminEvent/add?token={{ session.token }}">

                <div class="mb-3">
                    <label for="nomEvent" class="label-obligatoire">Nom de l'événement</label>
                    <input type="text" class="form-control inputGlobal" name="nom" id="nomEvent" aria-required="true" required>
                </div>

                <div class="mb-3">
                    <label for="descEvent" class="label-obligatoire">Description de l'événement</label>
                    <textarea class="form-control inputGlobal" name="description" rows="3" id="descEvent" aria-required="true" required></textarea>
                </div>

                <div class="row mb-3 ">
                    <div class="col-9">
                        <label for="dateEvent" class="label-obligatoire">Date de l'événement</label>
                        <input type="date" class="form-control inputGlobal" name="date_evenement" aria-required="true" id="dateEvent" required>
                    </div>
                    <div class="col-3">
                        <label for="prixEvent" class="label-obligatoire">Prix de l'événement</label>
                        <input type="number" class="form-control inputGlobal" name="prix" id="prixEvent" aria-required="true" required>
                    </div>
                </div>

                <label>On se déroule l'événement ?</label>
                <div class="card-image mb-3">
                    <div class="card-body">
                        <div id="map"></div>
                    </div>
                </div>

                <div class="row mb-3 ">
                    <div class="col-6">
                        <label for="lat-input" class="label-obligatoire">Latitude</label>
                        <input type="number" id="lat-input" name="latitude" step="0.000001" min="-90" max="90" class="form-control inputGlobal" aria-required="true" required>
                    </div>
                    <div class="col-6">
                        <label for="lng-input" class="label-obligatoire">Longitude</label>
                        <input type="number" id="lng-input" name="longitude" step="0.000001" min="-90" max="90" class="form-control inputGlobal" aria-required="true" required>
                    </div>
                </div>

                <div class="row mb-3 ">
                    <div class="col-6">
                        <label for="nomContact" class="label-obligatoire">Nom de la personne à contacter</label>
                        <input type="text" class="form-control inputGlobal" name="contact_nom" id="nomContact" aria-required="true" required>
                    </div>
                    <div class="col-6">
                        <label for="mailContact" class="label-obligatoire">Mail de la personne à contacter</label>
                        <input type="email" class="form-control inputGlobal" name="contact_email" id="mailContact" aria-required="true" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="imageEvent" class="label-obligatoire">Image de l'événement</label>
                    <input type="file" class="form-control inputGlobal custom-file-upload" name="Image" id="imageEvent" aria-required="true" required>
                </div>

                <div class="d-grid mt-5">
                    <button type="submit" class="btn btn-valider">Valider</button>
                </div>
            </form>
        </div>
    </div>


{% endblock %}

{% block javascript %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script type="text/javascript" src="/assets/js/map.js"></script>
<script type="text/javascript" src="/assets/js/script_article_add.js"></script>
{% endblock %}